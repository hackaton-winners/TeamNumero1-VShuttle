# =============================================================================
#  shuttle_backend — file di configurazione
#  Modifica questi valori senza toccare il codice.
# =============================================================================

# -----------------------------------------------------------------------------
# PATH FILE DI INPUT
# Inserisci qui il percorso assoluto o relativo al tuo file JSON degli scenari.
# -----------------------------------------------------------------------------
INPUT_JSON_PATH=data/input.json

# -----------------------------------------------------------------------------
# PESI IVW — SERVER ONLINE (V2I_receiver attivo)
#   Valore Finale = (P_server × W_SERVER) + (P_front × W_FRONTALE) + (P_lat × W_LATERALE)
#   La somma DEVE essere 1.0
# -----------------------------------------------------------------------------
W_SERVER=0.60
W_FRONTALE=0.30
W_LATERALE=0.10

# -----------------------------------------------------------------------------
# PESI IVW — SERVER OFFLINE (V2I_receiver = null)
#   La somma DEVE essere 1.0
# -----------------------------------------------------------------------------
W_FRONTALE_OFFLINE=0.75
W_LATERALE_OFFLINE=0.25

# -----------------------------------------------------------------------------
# SOGLIE DI CONFIDENZA
#   THRESHOLD_CERTAIN  : sopra questa soglia → GO o STOP (lettura certa)
#   THRESHOLD_UNCERTAIN: sotto questa soglia → sempre HUMAN_CONFIRM (troppo rumore)
#   Tra le due soglie  → HUMAN_CONFIRM (zona grigia)
# -----------------------------------------------------------------------------
THRESHOLD_CERTAIN=0.75
THRESHOLD_UNCERTAIN=0.50